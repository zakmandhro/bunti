{
  "name": "@zakmandhro/bunti",
  "version": "0.1.5",
  "description": "A Bun-native terminal layout engine with zero dependencies, 60fps rendering, and an agent-optimized functional API.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./geometry": {
      "types": "./dist/geometry.d.ts",
      "import": "./dist/geometry.js"
    },
    "./icons": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/icons.js"
    },
    "./icons-full": {
      "types": "./dist/icons-full.d.ts",
      "import": "./dist/icons-full.js"
    },
    "./layout": {
      "types": "./dist/layout.d.ts",
      "import": "./dist/layout.js"
    },
    "./render": {
      "types": "./dist/render.d.ts",
      "import": "./dist/render.js"
    },
    "./themes": {
      "types": "./dist/themes/index.d.ts",
      "import": "./dist/themes/index.js"
    }
  },
  "type": "module",
  "bin": {
    "bunti": "dist/cli.js"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && bun scripts/build-demos.ts",
    "gen:llms": "bun scripts/gen-llms.ts",
    "prepublishOnly": "bun run typecheck && bun run lint && bun run test && bun run gen:llms && bun run build",
    "test": "bun test",
    "smoke": "bun scripts/smoke-demos.ts",
    "bench": "bun scripts/bench.ts",
    "typecheck": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "demo": "bun demo/runner.ts",
    "example": "bun demo/runner.ts",
    "record": "vhs tapes/2048.tape",
    "record:animation": "vhs tapes/animation.tape",
    "record:mission-control": "vhs tapes/mission-control.tape",
    "record:all": "vhs tapes/2048.tape && vhs tapes/animation.tape && vhs tapes/mission-control.tape",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "tui",
    "cli",
    "terminal",
    "layout",
    "bun",
    "bunti"
  ],
  "author": "Zak Mandhro <zakmandhro@gmail.com>",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "AGENTS.md",
    "llms.txt"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.2",
    "typescript": "^5.4.0",
    "vitepress": "^1.6.4"
  }
}
