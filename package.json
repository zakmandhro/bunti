{
  "name": "@zakmandhro/bunti",
  "version": "0.1.0",
  "description": "A Bun-native terminal layout engine with zero dependencies, 60fps rendering, and an agent-optimized functional API.",
  "module": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./components": "./src/components/index.ts",
    "./icons": "./src/icons.ts",
    "./layout": "./src/layout.ts",
    "./render": "./src/render.ts"
  },
  "type": "module",
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "test": "bun test",
    "bench": "bun scripts/bench.ts",
    "typecheck": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "demo": "bun demo/runner.ts",
    "example": "bun demo/runner.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "tui",
    "cli",
    "terminal",
    "layout",
    "bun",
    "bunti"
  ],
  "author": "Zak Mandhro <zakmandhro@gmail.com>",
  "license": "MIT",
  "files": [
    "src"
  ],
  "peerDependencies": {
    "picocolors": "^1.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.2",
    "typescript": "^5.4.0",
    "vitepress": "^1.6.4"
  }
}
